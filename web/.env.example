# Postgres connection.
#
# Neon branching: use the `dev` branch locally so experiments don't touch
# production data. Vercel continues to use the `production` branch via its
# own env vars (set separately via `vercel env add`). Both branches share
# the same project and are identical at fork time thanks to Neon's
# copy-on-write.
#
# Get the dev branch connection string via:
#   - Neon console → project `instrumentar` → branch `dev` → Connect, OR
#   - MCP: mcp__Neon__get_connection_string({ branchId: 'br-old-recipe-al9j8dru' })
DATABASE_URI=postgresql://user:pass@ep-<dev-branch>-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Payload CMS session secret. Generate once, never commit the real one.
#   openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-random-32-char-string

# FastAPI backend URL. Locally you can point to prod Render or run the
# backend in a second terminal on http://localhost:8000 (CORS allows both).
NEXT_PUBLIC_BACKEND_URL=https://refactored-eureka-h7bs.onrender.com

# PostHog — GDPR-safe product analytics.
#
# Get the project API key from PostHog → Project settings → Project API Key.
# ALWAYS use the EU host (eu.i.posthog.com). Never point at app.posthog.com
# without re-reviewing the DPA — data would leave the EU.
#
# Local dev: leave these blank; lib/posthog.ts no-ops without a key so we
# don't pollute production counts with `pnpm dev` events.
# Vercel: set in all three scopes (production / preview / development) via
#   vercel env add NEXT_PUBLIC_POSTHOG_KEY
#   vercel env add NEXT_PUBLIC_POSTHOG_HOST
# Events are tagged with `environment` (production/preview/development) so
# they can be filtered in the PostHog UI.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
